# NPM Configuration for Electron + better-sqlite3

# Ensure native modules are rebuilt for Electron
# This helps prevent NODE_MODULE_VERSION mismatch errors
electron_mirror=https://npmmirror.com/mirrors/electron/
electron_builder_binaries_mirror=https://npmmirror.com/mirrors/electron-builder-binaries/

# Force rebuild on install
rebuild_native_modules=true

# Ensure postinstall scripts always run
ignore-scripts=false


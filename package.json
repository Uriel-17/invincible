{
  "name": "invincible",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "depcheck": "madge --circular src",
    "test": "npm run rebuild:node && vitest",
    "test:electron": "npm run rebuild:node && vitest --config vitest.electron.config.cjs && npm run rebuild:sqlite",
    "test:electron:ui": "npm run rebuild:node && vitest --config vitest.electron.config.cjs --ui",
    "test:electron:coverage": "npm run rebuild:node && vitest --config vitest.electron.config.cjs --coverage && npm run rebuild:sqlite",
    "test:all": "npm run rebuild:node && npm test -- --run && npm run test:electron -- --run && npm run rebuild:sqlite",
    "preview": "vite preview",
    "prepare": "husky",
    "postinstall": "npm run rebuild:sqlite",
    "rebuild": "npm run rebuild:sqlite",
    "rebuild:node": "npm rebuild better-sqlite3",
    "rebuild:sqlite": "electron-rebuild -f -w better-sqlite3 || echo '⚠️  Warning: electron-rebuild failed. Run: npm run rebuild:sqlite'",
    "electron": "NODE_ENV=development electron .",
    "electron:dev": "npm run rebuild:sqlite && concurrently \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron\"",
    "electron:build": "npm run build && electron-builder",
    "knip": "knip"
  },
  "main": "electron/main.cjs",
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.2",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-router": "^1.154.7",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-vite-plugin": "^1.154.7",
    "better-sqlite3": "^12.6.2",
    "i18next": "^25.7.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.1",
    "react-i18next": "^16.5.3",
    "recharts": "^3.7.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.9",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "eslint": "^9.39.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "knip": "^5.82.1",
    "madge": "^8.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.3"
  }
}
